  "keyFeatures": [
    "AI-generated personalized 4-week learning plans based on Moodle progress and soft skills assessments",
    "Adaptive focus cards prioritizing topics where coders struggle most",
    "AI-powered interactive chat tutor for on-demand learning assistance",
    "Team Leader analytics dashboard with risk detection for at-risk students",
    "Soft skills assessment integration (autonomy, time management, communication)",
    "Hybrid architecture with Node.js orchestrator and Python/FastAPI AI microservice",
    "OAuth authentication via GitHub and Google with email OTP verification",
    "Evidence submission system for completed learning activities"
  ],
